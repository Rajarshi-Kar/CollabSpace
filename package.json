{
  "name": "collabspace",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter @collabspace/api dev",
    "dev:worker": "pnpm --filter @collabspace/worker dev",
    "dev:web": "pnpm --filter @collabspace/web dev",
    "build": "pnpm -r build",
